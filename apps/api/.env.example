# @avion/api — NestJS realtime backend.
#
# Shares the SAME PostgreSQL as @avion/web. Set this to the identical
# DATABASE_URL used by apps/web/.env so the board reads real data.
DATABASE_URL=postgresql://postgres:postgres@localhost:5433/avion

# HTTP + WebSocket port the API listens on.
PORT=4000

# Allowed browser origin(s) for CORS + the Socket.IO handshake (comma-separated).
WEB_ORIGIN=http://localhost:3000

# How often (ms) the board gateway polls Postgres and broadcasts changes.
BOARD_POLL_MS=2000
