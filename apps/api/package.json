{
  "name": "@avion/api",
  "version": "0.1.0",
  "private": true,
  "description": "Avion realtime backend — NestJS REST API + Socket.IO board gateway over the shared PostgreSQL.",
  "scripts": {
    "build": "prisma generate && nest build",
    "dev": "prisma generate && nest start --watch",
    "start": "node dist/main.js",
    "start:prod": "node dist/main.js",
    "typecheck": "prisma generate && tsc --noEmit -p tsconfig.json",
    "prisma:generate": "prisma generate",
    "clean": "rm -rf dist .turbo src/generated"
  },
  "dependencies": {
    "@avion/shared": "workspace:*",
    "@nestjs/common": "^11.0.0",
    "@nestjs/config": "^4.0.0",
    "@nestjs/core": "^11.0.0",
    "@nestjs/platform-express": "^11.0.0",
    "@nestjs/platform-socket.io": "^11.0.0",
    "@nestjs/websockets": "^11.0.0",
    "@prisma/adapter-pg": "^7.8.0",
    "@prisma/client": "^7.8.0",
    "pg": "^8.22.0",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.1",
    "socket.io": "^4.8.1"
  },
  "devDependencies": {
    "@nestjs/cli": "^11.0.0",
    "@nestjs/schematics": "^11.0.0",
    "@types/node": "^20",
    "@types/pg": "^8.20.0",
    "prisma": "^7.8.0",
    "typescript": "^5"
  }
}
