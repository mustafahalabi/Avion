{
  "name": "avion-monorepo",
  "version": "0.1.0",
  "private": true,
  "packageManager": "pnpm@11.9.0",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "dev": "turbo run dev",
    "dev:web": "turbo run dev --filter=@avion/web",
    "dev:api": "turbo run dev --filter=@avion/api",
    "build": "turbo run build",
    "lint": "turbo run lint",
    "typecheck": "turbo run typecheck",
    "test": "turbo run test",
    "clean": "turbo run clean",
    "worker": "pnpm --filter @avion/web worker",
    "driver": "pnpm --filter @avion/web driver",
    "preview": "pnpm --filter @avion/web preview",
    "db:up": "docker compose up -d db",
    "db:down": "docker compose down",
    "db:generate": "pnpm --filter @avion/web exec prisma generate && pnpm --filter @avion/api exec prisma generate"
  },
  "devDependencies": {
    "turbo": "^2.10.3"
  }
}
