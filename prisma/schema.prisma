generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "sqlite"
}

// ─── Core User Model ─────────────────────────────────────────────────────────

model User {
  id        String   @id @default(cuid())
  clerkId   String?  @unique
  name      String?
  email     String   @unique
  image     String?
  role      String   @default("member")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  employee       Employee?
  ownedCompanies Company[] @relation("CompanyOwner")
}

// ─── Core Org Models ─────────────────────────────────────────────────────────

model Company {
  id          String   @id @default(cuid())
  name        String
  slug        String   @unique
  ownerId     String
  logoUrl     String?
  website     String?
  industry    String?
  description String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  owner                       User                         @relation("CompanyOwner", fields: [ownerId], references: [id])
  departments                 Department[]
  employees                   Employee[]
  settings                    CompanySettings?
  workspaces                  Workspace[]
  projects                    Project[]
  features                    Feature[]
  tasks                       Task[]
  memories                    Memory[]
  runtimeRequests             RuntimeRequest[]
  outcomes                    Outcome[]
  planningDrafts              PlanningDraft[]
  reviews                     Review[]
  qaResults                   QAResult[]
  releases                    Release[]
  conversations               Conversation[]
  integrations                Integration[]
  executionSessions           ExecutionSession[]
  repositoryAnalysisSnapshots RepositoryAnalysisSnapshot[]
  providerConnections         ProviderConnection[]
}

model Department {
  id          String   @id @default(cuid())
  name        String
  slug        String
  description String?
  companyId   String
  parentId    String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  company   Company      @relation(fields: [companyId], references: [id], onDelete: Cascade)
  parent    Department?  @relation("DepartmentHierarchy", fields: [parentId], references: [id])
  children  Department[] @relation("DepartmentHierarchy")
  employees Employee[]

  @@unique([companyId, slug])
}

model Role {
  id          String   @id @default(cuid())
  name        String
  level       Int      @default(0)
  description String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  employees Employee[]
}

model Employee {
  id               String    @id @default(cuid())
  userId           String?   @unique
  companyId        String
  departmentId     String?
  roleId           String?
  managerId        String?
  name             String
  title            String?
  mission          String?
  bio              String?
  responsibilities String?
  workload         String    @default("normal")
  reportsTo        String?
  startDate        DateTime?
  endDate          DateTime?
  status           String    @default("active")
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  user              User?              @relation(fields: [userId], references: [id], onDelete: Cascade)
  company           Company            @relation(fields: [companyId], references: [id], onDelete: Cascade)
  department        Department?        @relation(fields: [departmentId], references: [id])
  role              Role?              @relation(fields: [roleId], references: [id])
  manager           Employee?          @relation("EmployeeReporting", fields: [managerId], references: [id])
  reports           Employee[]         @relation("EmployeeReporting")
  assignedTasks     Task[]
  executionSessions ExecutionSession[]

  @@unique([companyId, id])
}

model CompanySettings {
  id             String   @id @default(cuid())
  companyId      String   @unique
  autonomyLevel  String   @default("assist")
  cultureProfile String   @default("startup")
  timezone       String   @default("UTC")
  currency       String   @default("USD")
  locale         String   @default("en")
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  company Company @relation(fields: [companyId], references: [id], onDelete: Cascade)
}

model Workspace {
  id          String   @id @default(cuid())
  name        String
  slug        String
  companyId   String
  description String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  company      Company      @relation(fields: [companyId], references: [id], onDelete: Cascade)
  projects     Project[]
  repositories Repository[]

  @@unique([companyId, slug])
  @@unique([companyId, id])
}

// ─── Engineering Work Models ─────────────────────────────────────────────────

model Repository {
  id              String   @id @default(cuid())
  workspaceId     String
  name            String
  url             String?
  description     String?
  primaryLanguage String?
  techStack       String   @default("[]")
  frameworks      String   @default("[]")
  dependencies    String   @default("[]")
  importantFiles  String   @default("[]")
  fileCount       Int?
  analysisStatus  String   @default("pending")
  analysisNotes   String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  workspace         Workspace                    @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  analysisSnapshots RepositoryAnalysisSnapshot[]
  executionSessions ExecutionSession[]
}

model RepositoryAnalysisSnapshot {
  id               String   @id @default(cuid())
  repositoryId     String
  companyId        String
  analyzerVersion  String
  status           String   @default("completed")
  error            String?
  localPath        String?
  fileTree         String   @default("{}")
  importantFiles   String   @default("[]")
  routes           String   @default("[]")
  apiRoutes        String   @default("[]")
  serverActions    String   @default("[]")
  prismaModels     String   @default("[]")
  dependencies     String   @default("[]")
  devDependencies  String   @default("[]")
  scripts          String   @default("{}")
  testFiles        String   @default("[]")
  fileFingerprints String   @default("[]")
  risks            String   @default("[]")
  ignoredPaths     String   @default("[]")
  analysisSummary  String?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  repository Repository @relation(fields: [repositoryId], references: [id], onDelete: Cascade)
  company    Company    @relation(fields: [companyId], references: [id], onDelete: Cascade)

  @@index([repositoryId, createdAt])
  @@index([companyId, createdAt])
}

model Project {
  id              String    @id @default(cuid())
  name            String
  slug            String
  companyId       String
  workspaceId     String
  outcomeId       String?
  planningDraftId String?
  planItemId      String?
  description     String?
  status          String    @default("active")
  startDate       DateTime?
  endDate         DateTime?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  company           Company            @relation(fields: [companyId], references: [id], onDelete: Cascade)
  workspace         Workspace          @relation(fields: [companyId, workspaceId], references: [companyId, id], onDelete: Cascade)
  outcome           Outcome?           @relation(fields: [companyId, outcomeId], references: [companyId, id], onDelete: Restrict)
  planningDraft     PlanningDraft?     @relation(fields: [companyId, planningDraftId], references: [companyId, id], onDelete: Restrict)
  features          Feature[]
  milestones        Milestone[]
  sprints           Sprint[]
  tasks             Task[]
  executionSessions ExecutionSession[]

  @@unique([companyId, id])
  @@unique([planningDraftId, planItemId])
}

model Feature {
  id              String   @id @default(cuid())
  title           String
  description     String?
  companyId       String
  projectId       String
  outcomeId       String?
  planningDraftId String?
  planItemId      String?
  status          String   @default("planned")
  priority        String   @default("medium")
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  company       Company        @relation(fields: [companyId], references: [id], onDelete: Cascade)
  project       Project        @relation(fields: [companyId, projectId], references: [companyId, id], onDelete: Cascade)
  outcome       Outcome?       @relation(fields: [companyId, outcomeId], references: [companyId, id], onDelete: Restrict)
  planningDraft PlanningDraft? @relation(fields: [companyId, planningDraftId], references: [companyId, id], onDelete: Restrict)
  tasks         Task[]

  @@unique([companyId, id])
  @@unique([planningDraftId, planItemId])
}

model Task {
  id              String   @id @default(cuid())
  title           String
  description     String?
  companyId       String
  projectId       String?
  featureId       String?
  sprintId        String?
  assigneeId      String?
  outcomeId       String?
  planningDraftId String?
  planItemId      String?
  status          String   @default("todo")
  priority        String   @default("medium")
  estimate        Float?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  company           Company            @relation(fields: [companyId], references: [id], onDelete: Cascade)
  project           Project?           @relation(fields: [companyId, projectId], references: [companyId, id], onDelete: Restrict)
  feature           Feature?           @relation(fields: [companyId, featureId], references: [companyId, id], onDelete: Restrict)
  sprint            Sprint?            @relation(fields: [sprintId], references: [id])
  assignee          Employee?          @relation(fields: [companyId, assigneeId], references: [companyId, id], onDelete: Restrict)
  outcome           Outcome?           @relation(fields: [companyId, outcomeId], references: [companyId, id], onDelete: Restrict)
  planningDraft     PlanningDraft?     @relation(fields: [companyId, planningDraftId], references: [companyId, id], onDelete: Restrict)
  subtasks          Subtask[]
  executionSessions ExecutionSession[]

  @@unique([companyId, id])
  @@unique([planningDraftId, planItemId])
}

model Subtask {
  id        String   @id @default(cuid())
  title     String
  taskId    String
  completed Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  task Task @relation(fields: [taskId], references: [id], onDelete: Cascade)
}

model Sprint {
  id        String    @id @default(cuid())
  name      String
  projectId String
  goal      String?
  status    String    @default("planned")
  startDate DateTime?
  endDate   DateTime?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
  tasks   Task[]
}

model Milestone {
  id          String    @id @default(cuid())
  title       String
  projectId   String
  description String?
  status      String    @default("pending")
  dueDate     DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
}

// ─── Memory / Knowledge Models ────────────────────────────────────────────────

model Memory {
  id        String   @id @default(cuid())
  companyId String
  title     String
  summary   String?
  category  String   @default("company")
  ownerType String?
  ownerId   String?
  tags      String   @default("[]")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  company Company        @relation(fields: [companyId], references: [id], onDelete: Cascade)
  records MemoryRecord[]
}

model MemoryRecord {
  id         String   @id @default(cuid())
  memoryId   String
  content    String
  source     String?
  confidence Float    @default(1.0)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  memory Memory @relation(fields: [memoryId], references: [id], onDelete: Cascade)
}

model Knowledge {
  id          String   @id @default(cuid())
  title       String
  description String?
  category    String?
  tags        String   @default("[]")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  records KnowledgeRecord[]
}

model KnowledgeRecord {
  id          String   @id @default(cuid())
  knowledgeId String
  content     String
  format      String   @default("markdown")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  knowledge Knowledge @relation(fields: [knowledgeId], references: [id], onDelete: Cascade)
}

// ─── Company Runtime Models ───────────────────────────────────────────────────

model RuntimeRequest {
  id            String   @id @default(cuid())
  companyId     String
  title         String
  goal          String
  requestType   String   @default("feature")
  status        String   @default("intake")
  assignedTo    String?
  clarification String?
  resolution    String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  company  Company        @relation(fields: [companyId], references: [id], onDelete: Cascade)
  events   RuntimeEvent[]
  messages Message[]
  outcome  Outcome?

  @@unique([companyId, id])
}

model RuntimeEvent {
  id          String   @id @default(cuid())
  requestId   String
  type        String
  description String
  actor       String?
  createdAt   DateTime @default(now())

  request RuntimeRequest @relation(fields: [requestId], references: [id], onDelete: Cascade)
}

// ─── Outcome Planning Models ──────────────────────────────────────────────────

model Outcome {
  id               String    @id @default(cuid())
  companyId        String
  runtimeRequestId String?   @unique
  title            String
  rawRequest       String
  brief            String?
  businessValue    String?
  successCriteria  String    @default("[]")
  constraints      String    @default("[]")
  status           String    @default("proposed")
  priority         String    @default("medium")
  ownerRole        String?
  failureReason    String?
  completedAt      DateTime?
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  company        Company         @relation(fields: [companyId], references: [id], onDelete: Cascade)
  runtimeRequest RuntimeRequest? @relation(fields: [companyId, runtimeRequestId], references: [companyId, id], onDelete: Restrict)
  planningDrafts PlanningDraft[]
  projects       Project[]
  features       Feature[]
  tasks          Task[]
  reviews        Review[]
  qaResults      QAResult[]
  releases       Release[]

  @@unique([companyId, id])
  @@unique([companyId, runtimeRequestId])
}

model PlanningDraft {
  id                     String    @id @default(cuid())
  companyId              String
  outcomeId              String
  title                  String
  summary                String?
  status                 String    @default("draft")
  version                Int       @default(1)
  scope                  String    @default("[]")
  nonScope               String    @default("[]")
  assumptions            String    @default("[]")
  risks                  String    @default("[]")
  dependencies           String    @default("[]")
  recommendedAssignments String    @default("[]")
  generatedProjects      String    @default("[]")
  generatedFeatures      String    @default("[]")
  generatedTasks         String    @default("[]")
  reviewPlan             String    @default("{}")
  qaPlan                 String    @default("{}")
  releasePlan            String    @default("{}")
  approvalNotes          String?
  rejectionReason        String?
  generationError        String?
  applicationError       String?
  approvedAt             DateTime?
  approvedById           String?
  rejectedAt             DateTime?
  rejectedById           String?
  appliedAt              DateTime?
  appliedById            String?
  createdAt              DateTime  @default(now())
  updatedAt              DateTime  @updatedAt

  company           Company            @relation(fields: [companyId], references: [id], onDelete: Cascade)
  outcome           Outcome            @relation(fields: [companyId, outcomeId], references: [companyId, id], onDelete: Cascade)
  projects          Project[]
  features          Feature[]
  tasks             Task[]
  reviews           Review[]
  qaResults         QAResult[]
  releases          Release[]
  executionSessions ExecutionSession[]

  @@unique([outcomeId, version])
  @@unique([companyId, id])
  @@unique([companyId, outcomeId, version])
}

// ─── Agent Execution Models ───────────────────────────────────────────────────
//
// ExecutionSession tracks a single implementation attempt for a task by an
// agent (Claude Code, Codex, human, etc.). It is company-scoped and links to
// task, project, repository, employee/role, and originating plan where
// available. No code execution is performed by Engineering OS itself — the
// session records what an external agent did.

model ExecutionSession {
  id        String @id @default(cuid())
  companyId String

  // ── Optional links ────────────────────────────────────────────────────────
  taskId          String? // Task being implemented
  projectId       String? // Project containing the task
  repositoryId    String? // Repository the agent will work in
  employeeId      String? // Assigned employee / recommended role
  planningDraftId String? // Originating planning draft

  // ── Agent metadata ────────────────────────────────────────────────────────
  // e.g. "claude_code" | "codex" | "human"
  agentType String @default("claude_code")

  // ── Status lifecycle ──────────────────────────────────────────────────────
  // "queued" | "prepared" | "running" | "completed" | "failed" | "canceled" | "needs_clarification"
  status String @default("queued")

  // ── Task brief ────────────────────────────────────────────────────────────
  // Copyable, agent-safe implementation brief generated for the session.
  // Populated when status transitions to "prepared".
  taskBrief String?

  // ── Execution results ─────────────────────────────────────────────────────
  // Human-readable summary of what the agent did (filled on completion).
  resultSummary    String?
  // JSON array of relative file paths changed: ["src/lib/foo.ts", ...]
  filesChanged     String  @default("[]")
  // Raw validation command output (tsc, lint, test, etc.) recorded by agent.
  validationOutput String?
  // Error message when status is "failed" or "needs_clarification".
  errorMessage     String?

  // ── Git / PR tracking ────────────────────────────────────────────────────
  // Implementation branch the agent should work on (derived from task ID + title).
  branchName  String?
  // Base branch the implementation branch is checked out from.
  baseBranch  String?
  // Commit SHA reported by the agent after completing work.
  commitSha   String?
  // Pull Request URL after the agent opens a PR.
  prUrl       String?
  // Pull Request number.
  prNumber    Int?
  // "open" | "draft" | "merged" | "closed"
  prStatus    String?
  // "pending" | "merged" | "conflicts"
  mergeStatus String?

  // ── Lifecycle timestamps ──────────────────────────────────────────────────
  startedAt   DateTime?
  completedAt DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  company       Company        @relation(fields: [companyId], references: [id], onDelete: Cascade)
  task          Task?          @relation(fields: [companyId, taskId], references: [companyId, id], onDelete: Restrict)
  project       Project?       @relation(fields: [companyId, projectId], references: [companyId, id], onDelete: Restrict)
  employee      Employee?      @relation(fields: [companyId, employeeId], references: [companyId, id], onDelete: Restrict)
  planningDraft PlanningDraft? @relation(fields: [companyId, planningDraftId], references: [companyId, id], onDelete: Restrict)
  repository    Repository?    @relation(fields: [repositoryId], references: [id], onDelete: Restrict)

  @@index([companyId, status])
  @@index([companyId, taskId])
}

// ─── Communication / Inbox Models ─────────────────────────────────────────────

model Conversation {
  id        String   @id @default(cuid())
  companyId String?
  title     String?
  type      String   @default("direct")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  company  Company?  @relation(fields: [companyId], references: [id], onDelete: Cascade)
  messages Message[]
}

model Message {
  id             String   @id @default(cuid())
  conversationId String
  authorId       String?
  role           String   @default("user")
  content        String
  type           String   @default("text")
  requestId      String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  conversation Conversation    @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  request      RuntimeRequest? @relation(fields: [requestId], references: [id], onDelete: SetNull)
}

model Notification {
  id         String    @id @default(cuid())
  userId     String
  companyId  String?
  title      String
  body       String?
  type       String    @default("info")
  priority   String    @default("medium")
  entityType String?
  entityId   String?
  actionUrl  String?
  read       Boolean   @default(false)
  readAt     DateTime?
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt
}

// ─── Timeline / Events ────────────────────────────────────────────────────────

model Event {
  id          String   @id @default(cuid())
  title       String
  description String?
  type        String   @default("generic")
  entityType  String?
  entityId    String?
  actorId     String?
  metadata    String   @default("{}")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model TimelineEntry {
  id         String   @id @default(cuid())
  entityType String
  entityId   String
  eventType  String
  summary    String?
  actorId    String?
  metadata   String   @default("{}")
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
}

// ─── Quality / Releases ───────────────────────────────────────────────────────

model Review {
  id                 String   @id @default(cuid())
  companyId          String
  title              String
  entityType         String   @default("task")
  entityId           String
  reviewerId         String?
  outcomeId          String?
  planningDraftId    String?
  planItemId         String?
  status             String   @default("pending")
  verdict            String?
  notes              String?
  changeRequestNotes String?
  // JSON array of ReviewFinding: [{ severity, description, actionable }]
  findings           String   @default("[]")
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  company        Company         @relation(fields: [companyId], references: [id], onDelete: Cascade)
  outcome        Outcome?        @relation(fields: [companyId, outcomeId], references: [companyId, id], onDelete: Restrict)
  planningDraft  PlanningDraft?  @relation(fields: [companyId, planningDraftId], references: [companyId, id], onDelete: Restrict)
  changeRequests ChangeRequest[]

  @@unique([planningDraftId, planItemId])
}

model QAResult {
  id              String   @id @default(cuid())
  companyId       String
  entityType      String   @default("task")
  entityId        String
  outcomeId       String?
  planningDraftId String?
  planItemId      String?
  status          String   @default("pending")
  passedCount     Int      @default(0)
  failedCount     Int      @default(0)
  notes           String?
  checks          String   @default("[]")
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  company       Company        @relation(fields: [companyId], references: [id], onDelete: Cascade)
  outcome       Outcome?       @relation(fields: [companyId, outcomeId], references: [companyId, id], onDelete: Restrict)
  planningDraft PlanningDraft? @relation(fields: [companyId, planningDraftId], references: [companyId, id], onDelete: Restrict)

  @@unique([planningDraftId, planItemId])
}

model ChangeRequest {
  id          String   @id @default(cuid())
  reviewId    String
  reason      String
  requestedBy String?
  resolution  String?
  resolved    Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  review Review @relation(fields: [reviewId], references: [id], onDelete: Cascade)
}

model Release {
  id               String    @id @default(cuid())
  companyId        String
  outcomeId        String?
  planningDraftId  String?
  planItemId       String?
  version          String
  title            String?
  description      String?
  releaseNotes     String?
  status           String    @default("draft")
  deploymentStatus String    @default("not_started")
  checklist        String    @default("[]")
  taskIds          String    @default("[]")
  rollbackPlan     String?
  postReleaseNotes String?
  releasedAt       DateTime?
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  company       Company        @relation(fields: [companyId], references: [id], onDelete: Cascade)
  outcome       Outcome?       @relation(fields: [companyId, outcomeId], references: [companyId, id], onDelete: Restrict)
  planningDraft PlanningDraft? @relation(fields: [companyId, planningDraftId], references: [companyId, id], onDelete: Restrict)

  @@unique([planningDraftId, planItemId])
}

model Incident {
  id          String    @id @default(cuid())
  title       String
  description String?
  severity    String    @default("medium")
  status      String    @default("open")
  resolvedAt  DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
}

// ─── Provider Connections ─────────────────────────────────────────────────────
//
// ProviderConnection is the first-class OAuth / app / manual-token model for
// connecting external providers (GitHub, Linear, Vercel, …) to a company.
// It co-exists with the legacy Integration model; existing Integration records
// are never touched by this model's migrations.

model ProviderConnection {
  id String @id @default(cuid())

  companyId String
  // null = company-level connection; set = personal/user-scoped connection
  userId    String?

  // Supported providers: "github" | "linear" | "vercel" — extensible to future providers
  provider String

  // "oauth" | "github_app" | "manual_token"
  connectionType String @default("oauth")

  // "connected" | "disconnected" | "error" | "expired" | "revoked" | "needs_reauth"
  status String @default("disconnected")

  // ── Connected account identity ─────────────────────────────────────────────
  // External account / installation ID (e.g. GitHub user ID, Linear user ID)
  externalAccountId    String?
  // Human-readable login / display name for the connected account
  externalAccountName  String?
  // Email address of the connected account when available
  externalAccountEmail String?

  // ── OAuth / app scope metadata ─────────────────────────────────────────────
  // JSON array of scope strings granted by the provider (e.g. ["repo","read:org"])
  scopes String @default("[]")

  // ── Encrypted token storage ────────────────────────────────────────────────
  // AES-256-GCM encrypted JSON produced by encryptCredentials() from
  // src/lib/credentials-crypto.ts.
  // Keys vary by provider: accessToken, refreshToken?, tokenType?,
  // installationId? (GitHub App), manualToken? (manual_token flow), etc.
  encryptedTokens  String    @default("{}")
  tokenExpiresAt   DateTime? // null = non-expiring or expiry unknown
  refreshAvailable Boolean   @default(false)

  // ── Error state ───────────────────────────────────────────────────────────
  errorCode    String?
  errorMessage String?

  // ── Lifecycle timestamps ──────────────────────────────────────────────────
  lastConnectedAt DateTime?
  disconnectedAt  DateTime?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  company Company @relation(fields: [companyId], references: [id], onDelete: Cascade)

  // One company-level connection per provider (userId IS NULL — enforced in service layer
  // because SQLite treats each NULL as distinct in composite unique indexes).
  // One user-scoped connection per provider per user per company.
  @@unique([companyId, provider, userId])
  @@index([companyId, provider])
  @@index([companyId, status])
}

model Integration {
  id           String    @id @default(cuid())
  companyId    String
  name         String
  provider     String
  status       String    @default("disconnected")
  config       String    @default("{}")
  credentials  String    @default("{}")
  lastSyncAt   DateTime?
  errorMessage String?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  company  Company              @relation(fields: [companyId], references: [id], onDelete: Cascade)
  syncLogs IntegrationSyncLog[]
}

model IntegrationSyncLog {
  id            String   @id @default(cuid())
  integrationId String
  status        String
  message       String
  recordsCount  Int      @default(0)
  createdAt     DateTime @default(now())

  integration Integration @relation(fields: [integrationId], references: [id], onDelete: Cascade)
}
