# Local SQLite database (for development; replace with a hosted URL in production)
DATABASE_URL="file:./dev.db"

# Clerk authentication — create a project at https://dashboard.clerk.com and copy these values
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY="pk_test_your_publishable_key_here"
CLERK_SECRET_KEY="sk_test_your_secret_key_here"

# Credential encryption key — AES-256-GCM key for storing integration credentials
# Generate with: node -e "require('crypto').randomBytes(32).toString('hex')"
CREDENTIALS_ENCRYPTION_KEY="your_64_char_hex_key_here"

# Clerk redirect URLs
NEXT_PUBLIC_CLERK_SIGN_IN_URL="/sign-in"
NEXT_PUBLIC_CLERK_SIGN_UP_URL="/sign-up"
NEXT_PUBLIC_CLERK_AFTER_SIGN_IN_URL="/dashboard"
NEXT_PUBLIC_CLERK_AFTER_SIGN_UP_URL="/onboarding"

# ─── Provider OAuth (GitHub / Linear) ───────────────────────────────────────────
# All optional: when a provider's client id/secret are absent the OAuth "Connect"
# buttons hide and the manual-token fallback stays available. Server-only — never
# prefix any of these with NEXT_PUBLIC_. See docs/integrations/OAUTH_SETUP.md for
# how to register each app and the exact callback URLs to configure.

# Absolute base URL Avion is served from. The OAuth callback URL is
# derived as ${OAUTH_REDIRECT_BASE_URL}/api/integrations/<provider>/callback and
# MUST byte-for-byte match what you register with each provider.
OAUTH_REDIRECT_BASE_URL="http://localhost:3000"

# Dedicated HMAC key for signing OAuth state tokens (CSRF). Distinct from
# CREDENTIALS_ENCRYPTION_KEY. Generate with:
#   node -e "require('crypto').randomBytes(32).toString('hex')"
OAUTH_STATE_SECRET="your_64_char_hex_key_here"

# GitHub OAuth App (classic) — https://github.com/settings/developers
GITHUB_OAUTH_CLIENT_ID=""
GITHUB_OAUTH_CLIENT_SECRET=""

# Linear OAuth application — https://linear.app/settings/api/applications
LINEAR_OAUTH_CLIENT_ID=""
LINEAR_OAUTH_CLIENT_SECRET=""
