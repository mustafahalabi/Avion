# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# Dependencies
node_modules/
.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# Build outputs
.next/
out/
dist/
build/
.turbo/

# Electron — staging output and packaged installers
release/
.electron-build/

# Testing
coverage/

# Env files — *.example are tracked; real env files are not
.env
.env.*
!.env.example

# Prisma generated clients + local databases
**/generated/prisma/
*.db
*.db-journal
*.db.bak*

# TypeScript
*.tsbuildinfo
next-env.d.ts

# Clerk keyless-mode local credentials
.clerk/

# npm lockfile — this repo is pnpm-only (pnpm-lock.yaml is the tracked lockfile)
package-lock.json

# Misc
.DS_Store
*.pem
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# Vercel
.vercel

# Local Claude Code config/commands (per-developer, not shared)
.claude/
