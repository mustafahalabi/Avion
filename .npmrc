# Use a flat (hoisted) node_modules like npm/yarn-classic.
# This keeps the Electron toolchain (electron-builder + @electron/rebuild) and
# any path-based native-module resolution in apps/web working under pnpm.
node-linker=hoisted

# Allow build scripts for these trusted native/build deps (pnpm blocks lifecycle
# scripts by default). Prisma needs its postinstall; Electron downloads its binary.
# pnpm reads this from the `onlyBuiltDependencies` field in package.json too, but
# keeping the linker hoisted is the load-bearing setting here.
strict-peer-dependencies=false
